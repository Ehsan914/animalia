// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  passwordHash  String
  @@map("admins")
}

model Vet {
  id            Int      @id @default(autoincrement())
  name          String
  degree        String
  designation   String
  bio           String   @db.Text
  fun_fact      String
  img_url       String
  experience    Int
  order         Int
  specialities  Speciality[]
  @@map("vets")
}

model Speciality {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  vets          Vet[]
  @@map("specialities")
}

model Service {
  id            Int      @id @default(autoincrement())
  title         String
  description   String   @db.Text
  price         Float
  order         Int
  img_url       String
  features      String[]
  appointments  AppointmentService[]
  @@map("services")
}

model Blog {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  
  // Bengali
  titleBn       String
  contentBn     String   @db.Text
  categoryBn    String
  
  // English
  titleEn       String
  contentEn     String   @db.Text
  categoryEn    String
  
  author        String
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  @@map("blogs")
}

model Review {
  id            Int      @id @default(autoincrement())
  author        String
  text          String   @db.Text
  rating        Int
  published     Boolean  @default(false)
  status        String
  createdAt     DateTime @default(now())
  @@map("reviews")
}

model Faq {
  id            Int      @id @default(autoincrement())
  questionBn    String
  answerBn      String   @db.Text
  questionEn    String
  answerEn      String   @db.Text
  order         Int
  @@map("faqs")
}

model Contact {
  id            Int      @id @default(autoincrement())
  phone         String
  email         String
  @@map("contacts")
}

model EmergencyContact {
  id            Int      @id @default(autoincrement())
  phone         String
  available24h  Boolean
  @@map("emergency_contacts")
}

model Location {
  id            Int      @id @default(autoincrement())
  address       String
  mapUrl        String
  @@map("locations")
}

model Appointment {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String
  email         String
  pet_name      String
  species       String
  services      AppointmentService[]
  date          DateTime
  message       String   @db.Text
  status        String   @default("pending")
  vetComment    String   @db.Text
  createdAt     DateTime @default(now())
  @@map("appointments")
}

model AppointmentService {
  appointmentId Int
  serviceId     Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appointmentId, serviceId])
  @@map("appointment_services")
}